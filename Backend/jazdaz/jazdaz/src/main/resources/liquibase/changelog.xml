<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-users" author="lucja">

        <createTable tableName="users">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="password_hash" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="role" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>

    </changeSet>


    <changeSet id="002-create-bus-lines" author="lucja">

        <createTable tableName="bus_lines">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <!-- route_id z routes.txt -->
            <column name="external_id" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>

            <!-- np. 105, 190, 520 -->
            <column name="line_number" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <!-- pełniejsza nazwa linii, opcjonalnie -->
            <column name="name" type="VARCHAR(255)"/>

            <!-- GTFS route_type, dla autobusu zwykle 3 -->
            <column name="route_type" type="INTEGER"/>
        </createTable>

    </changeSet>


    <changeSet id="003-create-bus-stops" author="lucja">

        <createTable tableName="bus_stops">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <!-- stop_id z stops.txt -->
            <column name="external_id" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>

            <!-- kod przystanku, jeżeli jest w GTFS -->
            <column name="stop_code" type="VARCHAR(50)"/>

            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="latitude" type="DECIMAL(10,7)">
                <constraints nullable="false"/>
            </column>

            <column name="longitude" type="DECIMAL(10,7)">
                <constraints nullable="false"/>
            </column>

            <!-- opcjonalne, przydatne w Warszawie dla słupków/peronów -->
            <column name="platform_code" type="VARCHAR(50)"/>
        </createTable>

    </changeSet>


    <changeSet id="004-create-bus-service-calendars" author="lucja">

        <createTable tableName="bus_service_calendars">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <!-- service_id z calendar.txt / calendar_dates.txt -->
            <column name="service_id" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="monday" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="tuesday" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="wednesday" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="thursday" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="friday" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="saturday" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="sunday" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="start_date" type="DATE"/>
            <column name="end_date" type="DATE"/>
        </createTable>

    </changeSet>


    <changeSet id="005-create-bus-service-calendar-dates" author="lucja">

        <createTable tableName="bus_service_calendar_dates">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="service_calendar_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>

            <!-- 1 = dodany kurs, 2 = usunięty kurs -->
            <column name="exception_type" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="bus_service_calendar_dates"
                baseColumnNames="service_calendar_id"
                referencedTableName="bus_service_calendars"
                referencedColumnNames="id"
                constraintName="fk_calendar_dates_calendar"/>

        <addUniqueConstraint
                tableName="bus_service_calendar_dates"
                columnNames="service_calendar_id, date"
                constraintName="uk_calendar_dates_service_date"/>

    </changeSet>


    <changeSet id="006-create-bus-trips" author="lucja">

        <createTable tableName="bus_trips">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <!-- trip_id z trips.txt -->
            <column name="external_id" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="line_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="service_calendar_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <!-- kierunek, np. krańcowy przystanek -->
            <column name="headsign" type="VARCHAR(255)"/>

            <!-- 0 / 1, kierunek jazdy -->
            <column name="direction_id" type="INTEGER"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="bus_trips"
                baseColumnNames="line_id"
                referencedTableName="bus_lines"
                referencedColumnNames="id"
                constraintName="fk_bus_trips_bus_lines"/>

        <addForeignKeyConstraint
                baseTableName="bus_trips"
                baseColumnNames="service_calendar_id"
                referencedTableName="bus_service_calendars"
                referencedColumnNames="id"
                constraintName="fk_bus_trips_calendar"/>

    </changeSet>


    <changeSet id="007-create-bus-stop-times" author="lucja">

        <createTable tableName="bus_stop_times">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="trip_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="stop_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <!-- kolejność przystanku na trasie -->
            <column name="stop_sequence" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <!-- jako tekst, bo GTFS może mieć godziny ponad 24:00:00 -->
            <column name="arrival_time" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>

            <column name="departure_time" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>

            <!-- pomocniczo do sortowania i wyszukiwania -->
            <column name="arrival_seconds" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="departure_seconds" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="bus_stop_times"
                baseColumnNames="trip_id"
                referencedTableName="bus_trips"
                referencedColumnNames="id"
                constraintName="fk_bus_stop_times_trips"/>

        <addForeignKeyConstraint
                baseTableName="bus_stop_times"
                baseColumnNames="stop_id"
                referencedTableName="bus_stops"
                referencedColumnNames="id"
                constraintName="fk_bus_stop_times_stops"/>

        <addUniqueConstraint
                tableName="bus_stop_times"
                columnNames="trip_id, stop_sequence"
                constraintName="uk_bus_stop_times_trip_sequence"/>

    </changeSet>


    <changeSet id="008-create-indexes" author="lucja">

        <createIndex tableName="bus_lines" indexName="idx_bus_lines_line_number">
            <column name="line_number"/>
        </createIndex>

        <createIndex tableName="bus_stops" indexName="idx_bus_stops_name">
            <column name="name"/>
        </createIndex>

        <createIndex tableName="bus_trips" indexName="idx_bus_trips_line_id">
            <column name="line_id"/>
        </createIndex>

        <createIndex tableName="bus_trips" indexName="idx_bus_trips_calendar_id">
            <column name="service_calendar_id"/>
        </createIndex>

        <createIndex tableName="bus_stop_times" indexName="idx_bus_stop_times_stop_id">
            <column name="stop_id"/>
        </createIndex>

        <createIndex tableName="bus_stop_times" indexName="idx_bus_stop_times_trip_id">
            <column name="trip_id"/>
        </createIndex>

        <createIndex tableName="bus_stop_times" indexName="idx_bus_stop_times_departure_seconds">
            <column name="departure_seconds"/>
        </createIndex>


    </changeSet>
    <changeSet id="009-create-ticket-types" author="lucja">
        <createTable tableName="ticket_types">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="price" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>

            <column name="duration_minutes" type="INTEGER"/>

            <column name="ticket_category" type="VARCHAR(50)"/>
        </createTable>
    </changeSet>
    <changeSet id="010-create-tickets" author="lucja">
        <createTable tableName="tickets">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="uuid" type="VARCHAR(36)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="ticket_type_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="qr_code" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="purchase_date" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="valid_from" type="TIMESTAMP"/>

            <column name="valid_to" type="TIMESTAMP"/>

            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="tickets"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_tickets_users"/>

        <addForeignKeyConstraint
                baseTableName="tickets"
                baseColumnNames="ticket_type_id"
                referencedTableName="ticket_types"
                referencedColumnNames="id"
                constraintName="fk_tickets_ticket_types"/>

        <createIndex tableName="tickets" indexName="idx_tickets_uuid">
            <column name="uuid"/>
        </createIndex>

        <createIndex tableName="tickets" indexName="idx_tickets_user_id">
            <column name="user_id"/>
        </createIndex>

        <createIndex tableName="tickets" indexName="idx_tickets_ticket_type_id">
            <column name="ticket_type_id"/>
        </createIndex>

        <createIndex tableName="tickets" indexName="idx_tickets_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>